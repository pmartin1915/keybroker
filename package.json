{
  "name": "keybroker",
  "version": "0.1.0",
  "description": "Prototype credential broker. Replaces shared API keys with short-lived, scoped, attributable tokens — without changing your application code.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "serve": "tsx src/cli.ts serve",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "web:install": "npm --prefix web install",
    "web:build": "npm --prefix web run build",
    "web:dev": "npm --prefix web run dev"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "commander": "^12.1.0",
    "fastify": "^5.0.0",
    "jose": "^5.9.6",
    "keytar": "^7.9.0",
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
